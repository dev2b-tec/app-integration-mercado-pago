    {
      "_id": "req_step1_card_token",
      "_type": "request",
      "parentId": "fld_cartao_fluxo",
      "name": "PASSO 1 — Tokenizar Cartão (MP direto)",
      "method": "POST",
      "url": "https://api.mercadopago.com/v1/card_tokens?public_key={{ _.mp_public_key }}",
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"card_number\": \"5031433215406351\",\n  \"expiration_year\": \"2030\",\n  \"expiration_month\": \"11\",\n  \"security_code\": \"123\",\n  \"cardholder\": {\n    \"name\": \"JESSE S BEZERRA\",\n    \"identification\": {\n      \"type\": \"CPF\",\n      \"number\": \"{{ _.payer_cpf }}\"\n    }\n  }\n}"
      }
    },
    {
      "_id": "req_step2_criar_assinatura_cartao",
