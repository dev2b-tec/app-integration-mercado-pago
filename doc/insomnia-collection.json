        "text": "{\n  \"empresaId\": \"{{ _.empresa_id }}\",\n  \"usuarioId\": \"{{ _.usuario_id }}\",\n  \"payerEmail\": \"{{ _.payer_email }}\",\n  \"planoTipo\": \"SMART_IA\",\n  \"cardTokenId\": \"{{ _.card_token_id }}\",\n  \"payerDocumento\": \"{{ _.payer_cpf }}\",\n  \"payerTipoDocumento\": \"CPF\"\n}"
      }
    },
